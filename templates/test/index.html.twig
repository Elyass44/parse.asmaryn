{% extends 'base.html.twig' %}

{% block title %}Tailwind Test{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-100 flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-lg p-10 max-w-md w-full text-center space-y-6">

        <h1 class="text-3xl font-bold text-gray-900">Tailwind is working</h1>
        <p class="text-gray-500 text-sm">If you can read this with proper styling, the setup is good.</p>

        <div class="flex justify-center gap-3">
            <span class="px-3 py-1 rounded-full bg-green-100 text-green-700 text-xs font-medium">Symfony 7.4</span>
            <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-medium">Tailwind CSS</span>
            <span class="px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-xs font-medium">AssetMapper</span>
        </div>

        <button class="w-full bg-gray-900 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-colors">
            Button test
        </button>

    </div>
