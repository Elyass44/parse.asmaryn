<!DOCTYPE html>
<html lang="{{ app.request ? app.request.locale : 'fr' }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Parse{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22><rect x=%222%22 y=%224%22 width=%2213%22 height=%2216%22 rx=%222%22 fill=%22%238b5cf6%22 opacity=%220.5%22/><rect x=%226%22 y=%222%22 width=%2213%22 height=%2216%22 rx=%222%22 fill=%22%237c3aed%22/></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
        {# Initialise dark mode before first paint to avoid flash of unstyled content #}
        <script>
            (function () {
                var theme = localStorage.getItem('theme');
                if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                    document.documentElement.classList.add('dark');
                }
            })();
        </script>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="font-sans bg-white dark:bg-slate-950 text-slate-900 dark:text-slate-100 antialiased">
        {% block body %}{% endblock %}

        {# ───────────────────────────── FOOTER ───────────────────────────── #}
        {% block site_footer %}
        <footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
                <div class="flex items-center justify-center sm:justify-end gap-4">
                    <nav class="flex items-center gap-4 flex-wrap justify-center" aria-label="Legal">
                        <a href="{{ path('web_privacy') }}" class="text-xs text-slate-500 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors">
                            {{ 'footer.privacy'|trans }}
                        </a>
                        <span class="text-slate-300 dark:text-slate-700" aria-hidden="true">·</span>
                        <a href="{{ path('web_terms') }}" class="text-xs text-slate-500 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors">
                            {{ 'footer.terms'|trans }}
                        </a>
                    </nav>
                </div>
            </div>
        </footer>
        {% endblock %}

        {# ─────────────────────── GDPR CONSENT BANNER ─────────────────────── #}
        {# TODO: If analytics or third-party scripts are ever added, update this banner text
           and the Privacy Policy BEFORE enabling those scripts. #}
        {% block consent_banner %}
        <div id="gdpr-banner"
             role="dialog"
             aria-modal="true"
             aria-label="{{ 'consent.dismiss'|trans }}"
             class="fixed bottom-0 inset-x-0 z-40 border-t border-slate-200 dark:border-slate-800 bg-white/95 dark:bg-slate-950/95 backdrop-blur-sm shadow-lg"
             style="display:none">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-6">
                    <p class="text-sm text-slate-600 dark:text-slate-400 flex-1">
                        {{ 'consent.message'|trans }}
                        <a href="{{ path('web_privacy') }}" class="underline text-violet-600 dark:text-violet-400 hover:text-violet-700 dark:hover:text-violet-300 ml-1">{{ 'consent.learn_more'|trans }}</a>
                    </p>
                    <button id="gdpr-dismiss"
                            class="flex-shrink-0 px-4 py-2 rounded-lg bg-violet-600 hover:bg-violet-700 active:bg-violet-800 text-white text-sm font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 dark:focus:ring-offset-slate-950">
                        {{ 'consent.dismiss'|trans }}
                    </button>
                </div>
            </div>
        </div>
        {% endblock %}
    </body>
</html>
