{% extends 'base.html.twig' %}

{% block body %}

{# ─── Minimal header ─── #}
<header class="fixed top-0 inset-x-0 z-50 h-16 flex items-center bg-white/80 dark:bg-slate-950/80 backdrop-blur-xl border-b border-slate-200/60 dark:border-slate-800/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full flex items-center justify-between">

        <a href="{{ path('home') }}" class="flex items-center gap-3">
            <span class="w-9 h-9 flex items-center justify-center rounded-xl bg-gradient-to-br from-violet-500 to-violet-700 shadow-lg shadow-violet-500/25 flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
            </span>
            <div class="leading-tight">
                <p class="text-sm font-bold bg-gradient-to-r from-violet-600 to-violet-800 dark:from-violet-400 dark:to-violet-500 bg-clip-text text-transparent">AI Resume Parser</p>
                <p class="text-[10px] text-slate-400 dark:text-slate-500 font-medium tracking-wide">by Asmaryn</p>
            </div>
        </a>

        <div class="flex items-center gap-2">
            <a href="{{ path('home') }}" class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold text-slate-600 dark:text-slate-400 hover:text-violet-600 dark:hover:text-violet-400 hover:bg-violet-50 dark:hover:bg-violet-950/40 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                {{ 'legal.back_home'|trans }}
            </a>

            <div class="flex items-center rounded-lg bg-slate-100 dark:bg-slate-800 p-0.5 gap-0.5">
                <a href="{{ path('switch_locale', {locale: 'en'}) }}"
                   class="px-2.5 py-1.5 rounded-md text-xs font-semibold transition-colors {% if app.request.locale == 'en' %}bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300{% endif %}">
                    EN
                </a>
                <a href="{{ path('switch_locale', {locale: 'fr'}) }}"
                   class="px-2.5 py-1.5 rounded-md text-xs font-semibold transition-colors {% if app.request.locale == 'fr' %}bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm{% else %}text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300{% endif %}">
                    FR
                </a>
            </div>

            <button id="theme-toggle" aria-label="Toggle theme"
                    class="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors text-slate-600 dark:text-slate-400">
                <svg id="icon-sun" class="w-4 h-4 hidden dark:block text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"></path>
                </svg>
                <svg id="icon-moon" class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                </svg>
            </button>
        </div>
    </div>
</header>

{# ─── Content ─── #}
<main class="pt-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16" data-legal-content>
        {% block legal_content %}{% endblock %}
    </div>
</main>

<script src="{{ asset('js/legal-placeholders.js') }}"></script>

{% endblock %}
